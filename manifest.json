{
  "manifest_version": 3,
  "name": "Corretor Brazuka",
  "version": "1.0",
  "description": "Sugere correções ortográficas ao clicar em palavras erradas.",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "alarms"
  ],
  "host_permissions": [
    "https://api.languagetool.org/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}